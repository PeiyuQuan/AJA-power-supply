record(mbbo, $(P)reqcontrol)
	{
		field(DESC, "Request release control")
		field(DTYP, "stream")
		field(OUT,"@AJA-powersupply.proto reqcontrol $(PORT)")
		field(ZRVL, "0x5554")
		field(ONVL, "0x5555")
		field(ZRST, "Non control")
		field(ONST, "control")
		field(SCAN, "1 second")
	}

record(bi, $(P)reqcontrolresult)
	{
		field(DESC, "The result of Request release control")
		field(DTYP, "stream")
		field(INP,"@AJA-powersupply.proto reqcontrol $(PORT)")
		field(ZNAM, "1")
		field(ONAM, "0")
	}
	
record(bo, $(P)Ping)
	{
		field(DESC, "check for communication with device")
		field(DTYP, "stream")
		field(OUT,"@AJA-powersupply.proto Ping $(PORT)")
	}
	
record(mbbo, $(P)RFonoff)
	{
		field(DESC, "RFONOFF")
		field(DTYP, "stream")
		field(OUT,"@AJA-powersupply.proto RFonoff $(PORT)")
		field(ZRVL, "0x5554")
		field(ONVL, "0x5555")
		field(ZRST, "OFF")
		field(ONST, "ON")
	}
	
