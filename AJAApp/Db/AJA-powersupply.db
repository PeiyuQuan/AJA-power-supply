	{
		field(DESC, "RF source")
		field(DTYP, "stream")
		field(OUT,"@AJA-powersupply.proto setuserlimit $(PORT)")
		field(HOPR, "4000")
		field(LOPR, "0")
		field(EGU, "watts")
	}

