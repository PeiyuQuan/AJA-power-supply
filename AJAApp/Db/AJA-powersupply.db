
record(mbbo, $(P)reqcontrol)
	{
		field(DESC, "1st AJA power supply")
		field(DTYP, "stream")
		field(OUT, "@AJA-powersupply.proto reqcontrol($(P)reqcontrolresult) $(PORT)")
		field(ZRVL, "0x5554")
		field(ONVL, "0x5555")
		field(ZRST, "Local")
		field(ONST, "remote")
		field(SCAN, "2 second")
	}

record(mbbi, $(P)reqcontrolresult)
	{
		field(DESC, "The result of Request release control")
		field(NOBT, "16")
		field(ZRVL, "0x5554")
		field(ZRST, "Local")
		field(ONVL, "0x5555")
		field(ONST, "remote")
	}
	
record(bo, $(P)Ping)
	{
		field(DESC, "check for communication with device")
		field(DTYP, "stream")
		field(OUT,"@AJA-powersupply.proto Ping $(PORT)")
	}
	
record(mbbo, $(P)RFonoff)
	{
		field(DESC, "RFONOFF")
		field(DTYP, "stream")
		field(OUT, "@AJA-powersupply.proto RFonoff $(PORT)")
		field(ZRVL, "0x5554")
		field(ONVL, "0x5555")
		field(ZRST, "OFF")
		field(ONST, "ON")
	}
	
record(ao, $(P)setpowerlevel)
	{
		field(DESC, "set point power")
		field(DTYP, "stream")
		field(OUT,"@AJA-powersupply.proto setpowerlevel $(PORT)")
		field(EGU, "watts")
		field(HOPR,"4000")
		field(LOPR,"0")
	}

record(ao, $(P)setaioscale)
	{
		field(DESC, "input/output scaling")
		field(DTYP, "stream")
		field(OUT,"@AJA-powersupply.proto setaioscale $(PORT)")
		field(EGU, "mV")
		field(HOPR,"10000")
		field(LOPR,"1000")
		field(PREC,"2")
	}
 	
record(mbbo, $(P)setoperatingmode)
	{
		field(DESC, "operation mode")
		field(DTYP, "stream")
		field(OUT,"@AJA-powersupply.proto setoperatingmode $(PORT)")
		field(ZRVL, "1")
		field(ONVL, "4")
		field(ZRST, "NORMAL")
		field(ONST, "RAMP")
	}

record(mbbo, $(P)setRFsource)
	{
		field(DESC, "RF source")
		field(DTYP, "stream")
		field(OUT,"@AJA-powersupply.proto setRFsource $(PORT)")
		field(ZRVL, "1")
		field(ONVL, "2")
		field(ZRST, "INTERNAL SOURCE")
		field(ONST, "EXTERNAL SOURCE")
	}

