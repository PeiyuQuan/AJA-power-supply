	}


record(ai, $(P)getFRQH)
	{
		field(DESC, "HI WORD")
		field(DTYP, "stream")
		field(INP,"@AJA-powersupply.proto getfrequency($(P)getFRQL) $(PORT)")
		field(EGU,"watts")
		field(SCAN, "1 second")
	}
	
record(ai, $(P)getFRQL)
	{
		field(DESC, "LO WORD")
		field(EGU,"watts")
	}
 
record(ai, $(P)getpowerSPlevel_read)
	{
		field(DESC, "present set point level")
		field(DTYP, "stream")
		field(INP,"@AJA-powersupply.proto getpowerSPlevel $(PORT)")
		field(EGU,"watts")
		field(HOPR, "4000")
		field(SCAN, "1 second")
		field(FLNK, "$(P)getpowerSPlevel")
	}
	
record(calc, $(P)getpowerSPlevel)
	{
#	field(INPA,"$(P)getpowerSPlevel.VAL NPP NMS")
	field(INPA,"$(P)getpowerSPlevel.VAL CP MS")
	field(CALC, "A/10")
	field(EGU,"watts")
	}
 
record(ai, $(P)getforwardpower)
	{
		field(DESC, "FORWARD POWER")
		field(DTYP, "stream")
		field(INP,"@AJA-powersupply.proto getpowerreading($(P)getreversepower,$(P)getloadpower) $(PORT)")
		field(EGU,"watts")
		field(SCAN, "1 second")
	}
	
record(ai, $(P)getreversepower)
	{
		field(DESC, "REVERSE POWER")
		field(EGU,"watts")
	}
	
record(ai, $(P)getloadpower)
	{
		field(DESC, "LOAD POWER")
		field(EGU,"watts")
	}
 
record(ai, $(P)getrampstart)
	{
		field(DESC, "ramp starting power")
		field(DTYP, "stream")
		field(INP,"@AJA-powersupply.proto getrampparameters($(P)getramprate) $(PORT)")
		field(EGU,"watts")
		field(SCAN, "1 second")
	}
	
record(ai, $(P)getramprate)
	{
		field(DESC, "ramp rate")
		field(EGU,"watts/second")
	}
 	
record(mbbiDirect, $(P)getgenStatus)
	{
		field(DESC, "STATUS")
		field(DTYP, "stream")
		field(INP,"@AJA-powersupply.proto getgenstatus($(P)getgenTemperature, $(P)getgenOpmode, $(P)getgenTuner) $(PORT)")
		field(B0, "1")
		field(B1, "0")
		field(B2, "0")
		field(B3, "0")
		field(B4, "1")
		field(B5, "0")
		field(B6, "0")
		field(B7, "0")
		field(B8, "1")
		field(B9, "1")
		field(BA, "1")
		field(BB, "1")
		field(BC, "0")
		field(BD, "0")
		field(BE, "1")
		field(BF, "0")
		field(SCAN, "1 second")
	}

record(mbbi, $(P)getgenTuner)
	{
		field(DESC, "RF source")
		field(ZRVL, "1")
		field(ONVL, "2")
		field(TWVL, "3")
		field(THVL, "4")
		field(ZRST, "NONE")
		field(ONST, "AFT GENERATOR")
		field(TWST, "ANALOG TUNER")
		field(THST, "DIGITAL TUNER")
	}

record(mbbi, $(P)getgenOpmode)
	{
		field(DESC, "opmode")
		field(ZRVL, "0")
		field(ZRST, "INVALID0")
		field(ONVL, "1")
		field(ONST, "NORMAL")
		field(TWVL, "2")
		field(TWST, "INVALID2")
		field(THVL, "3")
		field(THST, "INVALID3")
		field(FRVL, "4")
		field(FRST, "RAMP")
	}	
	
record(ai, $(P)getgenTemperature)
	{
		field(DESC, "TEMP")
		field(EGU,"Celsius")
		field(PREC,"1")
	}
	

record(mbbiDirect, $(P)gettunerStatus)
	{
		field(DESC, "STATUS")
		field(DTYP, "stream")
		field(INP,"@AJA-powersupply.proto gettunerstatus($(P)gettunerLCPOS, $(P)gettunerTCPOS, $(P)gettunerVDC) $(PORT)")
		field(B0, "1")
		field(B1, "1")
		field(B2, "0")
		field(B3, "0")
		field(B4, "1")
		field(B5, "1")
		field(B6, "1")
		field(B7, "1")
		field(B8, "0")
		field(B9, "0")
		field(BA, "0")
		field(BB, "0")
		field(BC, "0")
		field(BD, "0")
		field(BE, "1")
		field(BF, "0")
		field(SCAN, "1 second")
	}


record(ai, $(P)gettunerLCPOS)
	{
		field(DESC, "LOAD cap position")
	}
	
record(ai, $(P)gettunerTCPOS)
	{
		field(DESC, "TUNE cap position")
	}
	
record(ai, $(P)gettunerVDC)
	{
		field(DESC, "currently selected preset location")
		field(EGU,"volts")
	}
